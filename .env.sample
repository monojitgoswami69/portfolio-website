# Integrated chat configuration
GROQ_API_KEY=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
MODEL=llama-3.3-70b-versatile
DAILY_RATE_LIMIT=50
GLOBAL_RATE_LIMIT=1000
RATE_LIMIT_TIMEZONE=UTC
GUEST_SECRET=replace-with-a-long-random-secret
MAX_REQUEST_SIZE=1048576

# Admin authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=replace-with-a-long-random-secret

# Optional GitHub sync for src/data persistence
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
GITHUB_PROJECTS_FILE=src/data/projects.json
GITHUB_CONTACT_FILE=src/data/contact.json

# Optional admin database
DATABASE_URL=
